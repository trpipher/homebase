generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Link {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String
  createdAt   DateTime @default(now())
}

model Bill {
  id         String   @id @default(cuid())
  name       String
  provider   String?
  websiteUrl String
  accountNum String?
  dueDay     Int?
  notes      String?
  createdAt  DateTime @default(now())
}
